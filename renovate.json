{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchCategories": [
        "docker"
      ],
      "pinDigests": true
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "matchPackageNames": [
        "debian"
      ],
      "commitMessageTopic": "debian base image",
      "schedule": [
        "at any time"
      ]
    }
  ]
}
